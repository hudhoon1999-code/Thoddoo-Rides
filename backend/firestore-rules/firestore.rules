rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    function isApprovedDriver() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/drivers/$(request.auth.uid)).data.isApproved == true;
    }

    // ── Passengers ────────────────────────────────────────────────────────────

    match /passengers/{passengerId} {
      allow read:   if isOwner(passengerId) || isAdmin();
      allow create: if isOwner(passengerId);
      allow update: if isOwner(passengerId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalRides', 'createdAt']);
      allow delete: if isAdmin();
    }

    // ── Drivers ───────────────────────────────────────────────────────────────

    match /drivers/{driverId} {
      allow read:   if isOwner(driverId) || isAdmin();
      allow create: if isOwner(driverId);
      // Drivers can update their own location + status; admins can update approval/suspension
      allow update: if (isOwner(driverId) && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['currentLocation', 'locationUpdatedAt', 'isOnline', 'fcmToken', 'lastRideAt']))
                    || isAdmin();
      allow delete: if isAdmin();

      match /earnings/{earningId} {
        allow read:   if isOwner(driverId) || isAdmin();
        allow write:  if false; // Written only by Cloud Functions
      }

      match /daily_summaries/{date} {
        allow read:   if isOwner(driverId) || isAdmin();
        allow write:  if false;
      }
    }

    // ── Rides ─────────────────────────────────────────────────────────────────

    match /rides/{rideId} {
      allow read: if isSignedIn() && (
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId    == request.auth.uid ||
        isAdmin()
      );

      allow create: if isSignedIn() && request.resource.data.passengerId == request.auth.uid;

      allow update: if (
        // Passenger can cancel
        (resource.data.passengerId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt', 'cancelReason']))
        ||
        // Approved driver can update status during trip
        (isApprovedDriver() && resource.data.driverId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'driverLocation', 'actualFare', 'completedAt', 'arrivedAt', 'startedAt']))
        ||
        // Admin can do anything
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ── Driver ride requests ───────────────────────────────────────────────────

    match /driver_requests/{reqId} {
      allow read:   if isSignedIn() && (
        resource.data.driverId == request.auth.uid || isAdmin()
      );
      allow update: if isApprovedDriver() && resource.data.driverId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responded', 'response', 'respondedAt']);
      allow create: if false; // Written by Cloud Functions only
      allow delete: if isAdmin();
    }

    // ── Events ────────────────────────────────────────────────────────────────

    match /events/{eventId} {
      allow read:  if true;           // Public — passengers can read
      allow write: if isAdmin();
    }

    // ── Activities ────────────────────────────────────────────────────────────

    match /activities/{activityId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Pricing ───────────────────────────────────────────────────────────────

    match /pricing/{vehicleType} {
      allow read:  if isSignedIn();   // Authenticated users can read fare config
      allow write: if isAdmin();
    }

    // ── Vehicles ─────────────────────────────────────────────────────────────

    match /vehicles/{vehicleId} {
      allow read:   if isSignedIn();
      allow create: if isApprovedDriver() && request.resource.data.driverId == request.auth.uid;
      allow update: if (isApprovedDriver() && resource.data.driverId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────────

    match /notifications/{notifId} {
      allow read:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
      allow create: if false;
      allow delete: if isAdmin();
    }

    // ── Admins ────────────────────────────────────────────────────────────────

    match /admins/{adminId} {
      allow read:   if isAdmin();
      allow write:  if false; // Set manually in Firebase Console
    }

    // ── Admin action logs ─────────────────────────────────────────────────────

    match /admin_actions/{actionId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }
  }
}
